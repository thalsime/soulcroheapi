# Copie este arquivo para .env e ajuste os valores. NUNCA versione o .env.
# As variáveis são lidas com python-decouple.
#
# Chave secreta do Django (gere uma longa e aleatória). OBRIGATÓRIA em produção.
DJANGO_SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
# 0 = produção (recomendado no servidor); 1 = desenvolvimento local.
DJANGO_DEBUG=0
# Domínios que a API aceita atender (separados por vírgula).
# Mantenha localhost: o healthcheck do container acessa http://localhost:8000/.
DJANGO_ALLOWED_HOSTS=api.exemplo.com,localhost,127.0.0.1
# Origens confiáveis para o admin (login por trás do HTTPS do nginx).
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.exemplo.com
# CORS: deixe 1 (aberto a qualquer origem) enquanto o site cliente não tem
# domínio fixo. Sem esta linha, o padrão é FECHADO (seguro).
CORS_ALLOW_ALL_ORIGINS=1
# Fuso horário (padrão America/Sao_Paulo). Ajuste conforme a localidade do servidor.
DJANGO_TIME_ZONE=America/Sao_Paulo
# Caminho do banco SQLite (em produção fica no volume montado).
DJANGO_DB_PATH=/app/data/db.sqlite3
# Caminho onde o Django grava as imagens enviadas no admin (corresponde ao volume).
DJANGO_MEDIA_ROOT=/app/media
# Quantos itens por página nas listagens da API.
PAGE_SIZE=10
# Limite de envios do formulário de contato (opcional; padrão 30/min).
THROTTLE_CONTATO=30/min
